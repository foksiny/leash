fnc pi_leibniz(terms int) : float {
    pi: float = 0.0;
    sign: int = 1;
    i: int = 0;
    while i < terms {
        term: float = 1.0 / (float)(2 * i + 1);
        if sign == 1 {
            pi = pi + term;
        } else {
            pi = pi - term;
        }
        sign = -sign;
        i = i + 1;
    }
    return pi * 4.0;
}

fnc main() : void {
    terms: int = 10000000;
    pi: float = pi_leibniz(terms);
    show("pi (", terms, " terms): ", pi);
}
