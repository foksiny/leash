if _PLATFORM == "win64" {
    fnc main() : void {
        show("This is Windows!");
        file: File = File.open(_FILEPATH, "r");
        show(file.read());
        file.close();
    }
} else {
    fnc main() : void {
        file: File = File.open(_FILEPATH, "r");
        show(file.read());
        file.close();
    }
}

