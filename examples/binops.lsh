fnc main() : void {
    a: int = 1;
    b: int = 2;
    show(a + b);
    show(a - b);
    show(a * b);
    show(a / b);
    show(a % b);
    show(a & b);
    show(a | b);
    show(a ^ b);
    show(~a);
    show(a << b);
    show(a >> b);
    show(a == b);
    show(a != b);
    show(a < b);
    show(a > b);
    show(a <= b);
    show(a >= b);
    show(a && b);
    show(a || b);
    show(!a);
}