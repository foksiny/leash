priv def T : template;

pub def Tuple : class<T> {
    priv vals: vec<T>;
    pub size: int;

    static pub fnc new(vals T[]) : imut Tuple {
        return Tuple {vals: (vec<T>)vals, size: vals.size};
    }

    pub fnc get(idx int) : T {
        return this.vals.get(idx);
    }

    pub fnc isin(val T) : bool {
        return this.vals.isin(val);
    }
}
