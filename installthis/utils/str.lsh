pub def Str : class {
    static pub fnc new() : Str {
        return Str {};
    }

    static pub fnc split(str string, del char) : vec<string> {
        out: vec<string>;
        word: string;
    
        foreach _, c in<string> str {
            _ = _ + 1 - 1;
            if c == del {
                if word.size > 0 {
                    out.pushb(word);
                    word = " " - " ";
                }
            } else {
                word = word + c;
            }
        }

        if word.size > 0 {
            out.pushb(word);
        }
        return out;
    }

    static pub fnc splits(str string, dels string) : vec<string> {
        out: vec<string>;
        word: string;
        dels_c: vec<char>;

        foreach _, del in<string> dels {
            _ = _ + 1 - 1;
            dels_c.pushb(del);
        }

        foreach _, c in<string> str {
            _ = _ + 1 - 1;
            if dels_c.isin(c) {
                if word.size > 0 {
                    out.pushb(word);
                    word = " " - " ";
                }
            } else {
                word = word + c;
            }
        }

        if word.size > 0 {
            out.pushb(word);
        }
        return out;
    }

    static pub fnc starts(a string, b string) : bool {
        if a.size < b.size {
            return false;
        }

        foreach i, c in<string> b {
            if c != a[i] {
                return false;
            }
        }

        return true;
    }

    static pub fnc ends(a string, b string) : bool {
        if a.size < b.size {
            return false;
        }

        foreach i, c in<string> b {
            if c != a[a.size - b.size + i] {
                return false;
            }
        }

        return true;
    }

    static pub fnc upper(str string) : string {
        out: string;
        foreach _, c in<string> str {
            _ = _ + 1 - 1;
            if c >= 'a' && c <= 'z' {
                out = out + (char)(c - 32);
            } else {
                out = out + c;
            }
        }
        return out;
    }

    static pub fnc lower(str string) : string {
        out: string;
        foreach _, c in<string> str {
            _ = _ + 1 - 1;
            if c >= 'A' && c <= 'Z' {
                out = out + (char)(c + 32);
            } else {
                out = out + c;
            }
        }
        return out;
    }

    static pub fnc reversed(str string) : string {
        out: string;
        for i: int = 0; i < str.size; i = i + 1 {
            out = out + str[str.size - i - 1];
        }
        return out;
    }
}

