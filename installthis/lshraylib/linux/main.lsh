    //====================================================
    // Camera
    //====================================================

    def Camera3D : struct {
        position: Vector3;
        target: Vector3;
        up: Vector3;
        fovy: float<32>;
        projection: int;
    };

    def Camera : type Camera3D;

    def Camera2D : struct {
        offset: Vector2;
        target: Vector2;
        rotation: float<32>;
        zoom: float<32>;
    };

    //====================================================
    // Ray
    //====================================================

    def Ray : struct {
        position: Vector3;
        direction: Vector3;
    };

    def RayCollision : struct {
        hit: bool;
        distance: float<32>;
        point: Vector3;
        normal: Vector3;
    };

    //====================================================
    // Bounding Box
    //====================================================

    def BoundingBox : struct {
        min: Vector3;
        max: Vector3;
    };

    //====================================================
    // Vertex
    //====================================================

    def VertexAttribute : struct {
        typ: int;
        compSize: int;
        normalized: bool;
    };

    //====================================================
    // Transform
    //====================================================

    def Transform : struct {
        translation: Vector3;
        rotation: Vector4;
        scale: Vector3;
    };

    //====================================================
    // Bone
    //====================================================

    def BoneInfo : struct {
        name: string;
        parent: int;
    };

    //====================================================
    // Mesh
    //====================================================

    def Mesh : struct {

        vertexCount: int;
        triangleCount: int;

        vertices: pointer<float>;
        texcoords: pointer<float>;
        texcoords2: pointer<float>;
        normals: pointer<float>;
        tangents: pointer<float>;
        colors: pointer<uint<8>>;

        indices: pointer<uint<16>>;

        animVertices: pointer<float>;
        animNormals: pointer<float>;

        boneIds: pointer<uint<8>>;
        boneWeights: pointer<float>;

        vaoId: uint;

        vboId: pointer<uint>;
    };

    //====================================================
    // Shader
    //====================================================

    def Shader : struct {
        id: uint;
        locs: pointer<int>;
    };

    //====================================================
    // Material Map
    //====================================================

    def MaterialMap : struct {
        texture: Texture2D;
        color: Color;
        value: float<32>;
    };

    //====================================================
    // Material
    //====================================================

    def Material : struct {
        shader: Shader;
        maps: pointer<MaterialMap>;
        params: pointer<float>;
    };

    //====================================================
    // Model
    //====================================================

    def Model : struct {

        transform: Matrix;

        meshCount: int;
        materialCount: int;

        meshes: pointer<Mesh>;

        materials: pointer<Material>;

        meshMaterial: pointer<int>;

        boneCount: int;

        bones: pointer<BoneInfo>;

        bindPose: pointer<Transform>;
    };

    //====================================================
    // Animation
    //====================================================

    def ModelAnimation : struct {

        boneCount: int;

        frameCount: int;

        bones: pointer<BoneInfo>;

        framePoses: pointer<pointer<Transform>>;

        name: string;
    };

