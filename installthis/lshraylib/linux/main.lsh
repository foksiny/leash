    //====================================================

    def GlyphInfo : struct {
        value: int;
        offsetX: int;
        offsetY: int;
        advanceX: int;
        image: Image;
    };

    def Font : struct {
        baseSize: int;
        glyphCount: int;
        glyphPadding: int;

        texture: Texture2D;

        recs: pointer<Rectangle>;
        glyphs: pointer<GlyphInfo>;
    };

