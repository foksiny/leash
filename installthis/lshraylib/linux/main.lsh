    ) : Matrix;

    //====================================================
    // View
    //====================================================

    fnc MatrixLookAt(
        eye Vector3,
        target Vector3,
        up Vector3
    ) : Matrix;

    //====================================================
    // Quaternion conversion
    //====================================================

    fnc MatrixToFloat(
        mat Matrix
    ) : pointer<float>;

    //====================================================
    // Quaternion
    //====================================================
    // Na raylib, Quaternion é um alias de Vector4.
    // (x, y, z, w)

    def Quaternion : type Vector4;

    //====================================================
    // Basic
    //====================================================

    fnc QuaternionIdentity() : Quaternion;

    fnc QuaternionAdd(
        q1 Quaternion,
        q2 Quaternion
    ) : Quaternion;

    fnc QuaternionAddValue(
        q Quaternion,
        value float
    ) : Quaternion;

    fnc QuaternionSubtract(
        q1 Quaternion,
        q2 Quaternion
    ) : Quaternion;

    fnc QuaternionSubtractValue(
        q Quaternion,
        value float
    ) : Quaternion;

    fnc QuaternionScale(
        q Quaternion,
        scale float
    ) : Quaternion;

    fnc QuaternionDivide(
        q1 Quaternion,
        q2 Quaternion
    ) : Quaternion;

    fnc QuaternionNegate(
        q Quaternion
    ) : Quaternion;

    fnc QuaternionInvert(
        q Quaternion
    ) : Quaternion;

    fnc QuaternionNormalize(
        q Quaternion
    ) : Quaternion;

    fnc QuaternionLength(
        q Quaternion
    ) : float<32>;

    fnc QuaternionDotProduct(
        q1 Quaternion,
        q2 Quaternion
    ) : float<32>;

    //====================================================
    // Interpolation
    //====================================================

    fnc QuaternionLerp(
        q1 Quaternion,
        q2 Quaternion,
        amount float
    ) : Quaternion;

    fnc QuaternionNlerp(
        q1 Quaternion,
        q2 Quaternion,
        amount float
    ) : Quaternion;

    fnc QuaternionSlerp(
        q1 Quaternion,
        q2 Quaternion,
        amount float
    ) : Quaternion;

    //====================================================
    // Multiply
    //====================================================

    fnc QuaternionMultiply(
        q1 Quaternion,
        q2 Quaternion
    ) : Quaternion;

    //====================================================
    // Conversion
    //====================================================

    fnc QuaternionFromVector3ToVector3(
        from Vector3,
        to Vector3
    ) : Quaternion;

    fnc QuaternionFromMatrix(
        mat Matrix
    ) : Quaternion;

    fnc QuaternionToMatrix(
        q Quaternion
    ) : Matrix;

    fnc QuaternionFromAxisAngle(
        axis Vector3,
        angle float
    ) : Quaternion;

    fnc QuaternionToAxisAngle(
        q Quaternion,
        axis pointer<Vector3>,
        angle pointer<float>
    ) : void;

    fnc QuaternionFromEuler(
        pitch float<32>,
        yaw float<32>,
        roll float
    ) : Quaternion;

    fnc QuaternionToEuler(
        q Quaternion
    ) : Vector3;

    //====================================================
    // Transform
    //====================================================

    fnc QuaternionTransform(
        q Quaternion,
        mat Matrix
    ) : Quaternion;

    //====================================================
    // Equality
    //====================================================

    fnc QuaternionEquals(
        p Quaternion,
        q Quaternion
    ) : bool;

};

