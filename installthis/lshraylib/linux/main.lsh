@from("libraylib.a") {

    //====================================================
    // Basic structs
    //====================================================

    def Color : struct {
        r: uint<8>;
        g: uint<8>;
        b: uint<8>;
        a: uint<8>;
    };

    def Vector2 : struct {
        x: float<32>;
        y: float<32>;
    };

    def Vector3 : struct {
        x: float<32>;
        y: float<32>;
        z: float<32>;
    };

    def Vector4 : struct {
        x: float<32>;
        y: float<32>;
        z: float<32>;
        w: float<32>;
    };

    def Rectangle : struct {
        x: float<32>;
        y: float<32>;
        width: float<32>;
        height: float<32>;
    };

    def Matrix : struct {
        m0: float<32>;
        m4: float<32>;
        m8: float<32>;
        m12: float<32>;

        m1: float<32>;
        m5: float<32>;
        m9: float<32>;
        m13: float<32>;

        m2: float<32>;
        m6: float<32>;
        m10: float<32>;
        m14: float<32>;

        m3: float<32>;
        m7: float<32>;
        m11: float<32>;
        m15: float<32>;
    };

    //====================================================
    // Window
    //====================================================

    fnc InitWindow(width int, height int, title string) : void;
    fnc CloseWindow() : void;
    fnc WindowShouldClose() : bool;

    fnc IsWindowReady() : bool;
    fnc IsWindowFullscreen() : bool;
    fnc IsWindowHidden() : bool;
    fnc IsWindowMinimized() : bool;
    fnc IsWindowMaximized() : bool;
    fnc IsWindowFocused() : bool;
    fnc IsWindowResized() : bool;
    fnc IsWindowState(flag uint) : bool;

    fnc SetWindowState(flags uint) : void;
    fnc ClearWindowState(flags uint) : void;

    fnc ToggleFullscreen() : void;
    fnc ToggleBorderlessWindowed() : void;

    fnc MaximizeWindow() : void;
    fnc MinimizeWindow() : void;
    fnc RestoreWindow() : void;

    fnc SetWindowIcon(image pointer<void>) : void;
    fnc SetWindowIcons(images pointer<void>, count int) : void;

    fnc SetWindowTitle(title string) : void;
    fnc SetWindowPosition(x int, y int) : void;
    fnc SetWindowMonitor(monitor int) : void;
    fnc SetWindowMinSize(width int, height int) : void;
    fnc SetWindowMaxSize(width int, height int) : void;
    fnc SetWindowSize(width int, height int) : void;
    fnc SetWindowOpacity(opacity float<32>) : void;

    fnc SetWindowFocused() : void;

    fnc GetWindowHandle() : pointer<void>;

    fnc GetScreenWidth() : int;
    fnc GetScreenHeight() : int;

    fnc GetRenderWidth() : int;
    fnc GetRenderHeight() : int;

    fnc GetMonitorCount() : int;
    fnc GetCurrentMonitor() : int;

    fnc GetMonitorPosition(monitor int) : Vector2;

    fnc GetMonitorWidth(monitor int) : int;
    fnc GetMonitorHeight(monitor int) : int;

    fnc GetMonitorPhysicalWidth(monitor int) : int;
    fnc GetMonitorPhysicalHeight(monitor int) : int;

    fnc GetMonitorRefreshRate(monitor int) : int;

    fnc GetWindowPosition() : Vector2;
    fnc GetWindowScaleDPI() : Vector2;

    fnc GetMonitorName(monitor int) : string;

    fnc SetClipboardText(text string) : void;
    fnc GetClipboardText() : string;

    fnc EnableEventWaiting() : void;
    fnc DisableEventWaiting() : void;

    //====================================================
    // Cursor
    //====================================================

    fnc ShowCursor() : void;
    fnc HideCursor() : void;

    fnc IsCursorHidden() : bool;
    fnc EnableCursor() : void;
    fnc DisableCursor() : void;

    fnc IsCursorOnScreen() : bool;

    //====================================================
    // Drawing
    //====================================================

    fnc BeginDrawing() : void;
    fnc EndDrawing() : void;

    fnc ClearBackground(color Color) : void;

    //====================================================
    // Timing
    //====================================================

    fnc SetTargetFPS(fps int) : void;

    fnc GetFPS() : int;

    fnc GetFrameTime() : float<32>;

    fnc GetTime() : float<32>;

    //====================================================
    // Keyboard
    //====================================================

    fnc IsKeyPressed(key int) : bool;
    fnc IsKeyPressedRepeat(key int) : bool;
    fnc IsKeyDown(key int) : bool;
    fnc IsKeyReleased(key int) : bool;
    fnc IsKeyUp(key int) : bool;

    fnc GetKeyPressed() : int;
    fnc GetCharPressed() : int;

    fnc SetExitKey(key int) : void;

    //====================================================
    // Mouse
    //====================================================

    fnc IsMouseButtonPressed(button int) : bool;
    fnc IsMouseButtonDown(button int) : bool;
    fnc IsMouseButtonReleased(button int) : bool;
    fnc IsMouseButtonUp(button int) : bool;

    fnc GetMouseX() : int;
    fnc GetMouseY() : int;

    fnc GetMousePosition() : Vector2;

    fnc GetMouseDelta() : Vector2;

    fnc SetMousePosition(x int, y int) : void;

    fnc SetMouseOffset(offsetx int, offsety int) : void;

    fnc SetMouseScale(scaleX float<32>, scaleY float<32>) : void;

    fnc GetMouseWheelMove() : float<32>;

    fnc GetMouseWheelMoveV() : Vector2;

    fnc SetMouseCursor(cursor int) : void;

    //====================================================
    // Gamepad
    //====================================================

    fnc IsGamepadAvailable(gamepad int) : bool;

    fnc GetGamepadName(gamepad int) : string;

    fnc IsGamepadButtonPressed(gamepad int, button int) : bool;
    fnc IsGamepadButtonDown(gamepad int, button int) : bool;
    fnc IsGamepadButtonReleased(gamepad int, button int) : bool;
    fnc IsGamepadButtonUp(gamepad int, button int) : bool;

    fnc GetGamepadButtonPressed() : int;

    fnc GetGamepadAxisCount(gamepad int) : int;

    fnc GetGamepadAxisMovement(gamepad int, axis int) : float<32>;

    fnc SetGamepadMappings(mappings string) : int;

    //====================================================
    // Gestures
    //====================================================

    fnc SetGesturesEnabled(flags uint) : void;

    fnc IsGestureDetected(gesture int) : bool;

    fnc GetGestureDetected() : int;

    fnc GetGestureHoldDuration() : float<32>;

    fnc GetGestureDragVector() : Vector2;
    fnc GetGestureDragAngle() : float<32>;

    fnc GetGesturePinchVector() : Vector2;
    fnc GetGesturePinchAngle() : float<32>;

    //====================================================
    // Pixel
    //====================================================

    fnc DrawPixel(posX int, posY int, color Color) : void;
    fnc DrawPixelV(position Vector2, color Color) : void;

    //====================================================
    // Lines
    //====================================================

    fnc DrawLine(startPosX int, startPosY int,
                 endPosX int, endPosY int,
                 color Color) : void;

    fnc DrawLineV(startPos Vector2,
                  endPos Vector2,
                  color Color) : void;

    fnc DrawLineEx(startPos Vector2,
                   endPos Vector2,
                   thick float<32>,
                   color Color) : void;

    fnc DrawLineStrip(points pointer<Vector2>,
                      pointCount int,
                      color Color) : void;

    fnc DrawLineBezier(startPos Vector2,
                       endPos Vector2,
                       thick float<32>,
                       color Color) : void;

    //====================================================
    // Circles
    //====================================================

    fnc DrawCircle(centerX int,
                   centerY int,
                   radius float<32>,
                   color Color) : void;

    fnc DrawCircleSector(center Vector2,
                         radius float<32>,
                         startAngle float<32>,
                         endAngle float<32>,
                         segments int,
                         color Color) : void;

    fnc DrawCircleSectorLines(center Vector2,
                              radius float<32>,
                              startAngle float<32>,
                              endAngle float<32>,
                              segments int,
                              color Color) : void;

    fnc DrawCircleGradient(centerX int,
                           centerY int,
                           radius float<32>,
                           inner Color,
                           outer Color) : void;

    fnc DrawCircleV(center Vector2,
                    radius float<32>,
                    color Color) : void;

    fnc DrawCircleLines(centerX int,
                        centerY int,
                        radius float<32>,
                        color Color) : void;

    fnc DrawCircleLinesV(center Vector2,
                         radius float<32>,
                         color Color) : void;

    //====================================================
    // Ellipses
    //====================================================

    fnc DrawEllipse(centerX int,
                    centerY int,
                    radiusH float<32>,
                    radiusV float<32>,
                    color Color) : void;

    fnc DrawEllipseLines(centerX int,
                         centerY int,
                         radiusH float<32>,
                         radiusV float<32>,
                         color Color) : void;

    //====================================================
    // Rings
    //====================================================

    fnc DrawRing(center Vector2,
                 innerRadius float<32>,
                 outerRadius float<32>,
                 startAngle float<32>,
                 endAngle float<32>,
                 segments int,
                 color Color) : void;

    fnc DrawRingLines(center Vector2,
                      innerRadius float<32>,
                      outerRadius float<32>,
                      startAngle float<32>,
                      endAngle float<32>,
                      segments int,
                      color Color) : void;

    //====================================================
    // Rectangles
    //====================================================

    fnc DrawRectangle(posX int,
                      posY int,
                      width int,
                      height int,
                      color Color) : void;

    fnc DrawRectangleV(position Vector2,
                       size Vector2,
                       color Color) : void;

    fnc DrawRectangleRec(rec Rectangle,
                         color Color) : void;

    fnc DrawRectanglePro(rec Rectangle,
                         origin Vector2,
                         rotation float<32>,
                         color Color) : void;

    fnc DrawRectangleGradientV(posX int,
                               posY int,
                               width int,
                               height int,
                               top Color,
                               bottom Color) : void;

    fnc DrawRectangleGradientH(posX int,
                               posY int,
                               width int,
                               height int,
                               left Color,
                               right Color) : void;

    fnc DrawRectangleGradientEx(rec Rectangle,
                                topLeft Color,
                                bottomLeft Color,
                                topRight Color,
                                bottomRight Color) : void;

    fnc DrawRectangleLines(posX int,
                           posY int,
                           width int,
                           height int,
                           color Color) : void;

    fnc DrawRectangleLinesEx(rec Rectangle,
                             lineThick float<32>,
                             color Color) : void;

    fnc DrawRectangleRounded(rec Rectangle,
                             roundness float<32>,
                             segments int,
                             color Color) : void;

    fnc DrawRectangleRoundedLines(rec Rectangle,
                                  roundness float<32>,
                                  segments int,
                                  lineThick float<32>,
                                  color Color) : void;

    //====================================================
    // Triangles
    //====================================================

    fnc DrawTriangle(v1 Vector2,
                     v2 Vector2,
                     v3 Vector2,
                     color Color) : void;

    fnc DrawTriangleLines(v1 Vector2,
                          v2 Vector2,
                          v3 Vector2,
                          color Color) : void;

    fnc DrawTriangleFan(points pointer<Vector2>,
                        pointCount int,
                        color Color) : void;

    fnc DrawTriangleStrip(points pointer<Vector2>,
                          pointCount int,
                          color Color) : void;

    //====================================================
    // Polygons
    //====================================================

    fnc DrawPoly(center Vector2,
                 sides int,
                 radius float<32>,
                 rotation float<32>,
                 color Color) : void;

    fnc DrawPolyLines(center Vector2,
                      sides int,
                      radius float<32>,
                      rotation float<32>,
                      color Color) : void;

    fnc DrawPolyLinesEx(center Vector2,
                        sides int,
                        radius float<32>,
                        rotation float<32>,
                        lineThick float<32>,
                        color Color) : void;

    //====================================================
    // Splines
    //====================================================

    fnc DrawSplineLinear(points pointer<Vector2>,
                         pointCount int,
                         thick float<32>,
                         color Color) : void;

    fnc DrawSplineBasis(points pointer<Vector2>,
                        pointCount int,
                        thick float<32>,
                        color Color) : void;

    fnc DrawSplineCatmullRom(points pointer<Vector2>,
                             pointCount int,
                             thick float<32>,
                             color Color) : void;

    fnc DrawSplineBezierQuadratic(points pointer<Vector2>,
                                  pointCount int,
                                  thick float<32>,
                                  color Color) : void;

    fnc DrawSplineBezierCubic(points pointer<Vector2>,
                              pointCount int,
                              thick float<32>,
                              color Color) : void;

    fnc GetSplinePointLinear(startPos Vector2,
                             endPos Vector2,
                             t float<32>) : Vector2;

    fnc GetSplinePointBasis(p1 Vector2,
                            p2 Vector2,
                            p3 Vector2,
                            p4 Vector2,
                            t float<32>) : Vector2;

    fnc GetSplinePointCatmullRom(p1 Vector2,
                                 p2 Vector2,
                                 p3 Vector2,
                                 p4 Vector2,
                                 t float<32>) : Vector2;

    fnc GetSplinePointBezierQuad(p1 Vector2,
                                 c2 Vector2,
                                 p3 Vector2,
                                 t float<32>) : Vector2;

    fnc GetSplinePointBezierCubic(p1 Vector2,
                                  c2 Vector2,
                                  c3 Vector2,
                                  p4 Vector2,
                                  t float<32>) : Vector2;

    //====================================================
    // Collision
    //====================================================

    fnc CheckCollisionRecs(rec1 Rectangle,
                           rec2 Rectangle) : bool;

    fnc CheckCollisionCircles(center1 Vector2,
                              radius1 float<32>,
                              center2 Vector2,
                              radius2 float<32>) : bool;

    fnc CheckCollisionCircleRec(center Vector2,
                                radius float<32>,
                                rec Rectangle) : bool;

    fnc CheckCollisionPointRec(point Vector2,
                               rec Rectangle) : bool;

    fnc CheckCollisionPointCircle(point Vector2,
                                  center Vector2,
                                  radius float<32>) : bool;

    fnc CheckCollisionPointTriangle(point Vector2,
                                    p1 Vector2,
                                    p2 Vector2,
                                    p3 Vector2) : bool;

    fnc CheckCollisionPointPoly(point Vector2,
                                points pointer<Vector2>,
                                pointCount int) : bool;

    fnc CheckCollisionLines(startPos1 Vector2,
                            endPos1 Vector2,
                            startPos2 Vector2,
                            endPos2 Vector2,
                            collisionPoint pointer<Vector2>) : bool;

    fnc CheckCollisionPointLine(point Vector2,
                                p1 Vector2,
                                p2 Vector2,
                                threshold int) : bool;

    fnc GetCollisionRec(rec1 Rectangle,
                        rec2 Rectangle) : Rectangle;

    //====================================================
    // Structs
    //====================================================

    def Image : struct {
        data: pointer<void>;
        width: int;
        height: int;
        mipmaps: int;
        format: int;
    };

    def Texture : struct {
        id: uint;
        width: int;
        height: int;
        mipmaps: int;
        format: int;
    };

    def Texture2D : type Texture;

    def TextureCubemap : type Texture;

    def RenderTexture : struct {
        id: uint;
        texture: Texture;
        depth: Texture;
    };

    def RenderTexture2D : type RenderTexture;

    def NPatchInfo : struct {
        source: Rectangle;

        left: int;
        top: int;
        right: int;
        bottom: int;

        layout: int;
    };

    //====================================================
    // Image loading
    //====================================================

    fnc LoadImage(fileName string) : Image;

    fnc LoadImageRaw(
        fileName string,
        width int,
        height int,
        format int,
        headerSize int
    ) : Image;

    fnc LoadImageSvg(
        fileName string,
        width int,
        height int
    ) : Image;

    fnc LoadImageAnim(
        fileName string,
        frames pointer<int>
    ) : Image;

    fnc LoadImageAnimFromMemory(
        fileType string,
        fileData pointer<uint<8>>,
        dataSize int,
        frames pointer<int>
    ) : Image;

    fnc LoadImageFromMemory(
        fileType string,
        fileData pointer<uint<8>>,
        dataSize int
    ) : Image;

    fnc LoadImageFromTexture(
        texture Texture2D
    ) : Image;

    fnc LoadImageFromScreen() : Image;

    fnc IsImageValid(
        image Image
    ) : bool;

    fnc UnloadImage(
        image Image
    ) : void;

    fnc ExportImage(
        image Image,
        fileName string
    ) : bool;

    fnc ExportImageToMemory(
        image Image,
        fileType string,
        fileSize pointer<int>
    ) : pointer<uint<8>>;

    fnc ExportImageAsCode(
        image Image,
        fileName string
    ) : bool;

    //====================================================
    // Image generation
    //====================================================

    fnc GenImageColor(
        width int,
        height int,
        color Color
    ) : Image;

    fnc GenImageGradientLinear(
        width int,
        height int,
        direction int,
        start Color,
        end Color
    ) : Image;

    fnc GenImageGradientRadial(
        width int,
        height int,
        density float<32>,
        inner Color,
        outer Color
    ) : Image;

    fnc GenImageGradientSquare(
        width int,
        height int,
        density float<32>,
        inner Color,
        outer Color
    ) : Image;

    fnc GenImageChecked(
        width int,
        height int,
        checksX int,
        checksY int,
        col1 Color,
        col2 Color
    ) : Image;

    fnc GenImageWhiteNoise(
        width int,
        height int,
        factor float
    ) : Image;

    fnc GenImagePerlinNoise(
        width int,
        height int,
        offsetX int,
        offsetY int,
        scale float
    ) : Image;

    fnc GenImageCellular(
        width int,
        height int,
        tileSize int
    ) : Image;

    fnc GenImageText(
        width int,
        height int,
        text string
    ) : Image;

    //====================================================
    // Image copy
    //====================================================

    fnc ImageCopy(
        image Image
    ) : Image;

    fnc ImageFromImage(
        image Image,
        rec Rectangle
    ) : Image;

    fnc ImageText(
        text string,
        fontSize int,
        color Color
    ) : Image;

    fnc ImageTextEx(
        font pointer<void>,
        text string,
        fontSize float<32>,
        spacing float<32>,
        tint Color
    ) : Image;

    //====================================================
    // Format
    //====================================================

    fnc ImageFormat(
        image pointer<Image>,
        newFormat int
    ) : void;

    fnc ImageToPOT(
        image pointer<Image>,
        fill Color
    ) : void;

    //====================================================
    // Crop
    //====================================================

    fnc ImageCrop(
        image pointer<Image>,
        crop Rectangle
    ) : void;

    fnc ImageAlphaCrop(
        image pointer<Image>,
        threshold float
    ) : void;

    //====================================================
    // Alpha
    //====================================================

    fnc ImageAlphaClear(
        image pointer<Image>,
        color Color,
        threshold float
    ) : void;

    fnc ImageAlphaMask(
        image pointer<Image>,
        alphaMask Image
    ) : void;

    fnc ImageAlphaPremultiply(
        image pointer<Image>
    ) : void;

    //====================================================
    // Blur
    //====================================================

    fnc ImageBlurGaussian(
        image pointer<Image>,
        blurSize int
    ) : void;

    //====================================================
    // Resize
    //====================================================

    fnc ImageResize(
        image pointer<Image>,
        newWidth int,
        newHeight int
    ) : void;

    fnc ImageResizeNN(
        image pointer<Image>,
        newWidth int,
        newHeight int
    ) : void;

    fnc ImageResizeCanvas(
        image pointer<Image>,
        newWidth int,
        newHeight int,
        offsetX int,
        offsetY int,
        fill Color
    ) : void;

    //====================================================
    // Mipmaps
    //====================================================

    fnc ImageMipmaps(
        image pointer<Image>
    ) : void;

    fnc ImageDither(
        image pointer<Image>,
        rBpp int,
        gBpp int,
        bBpp int,
        aBpp int
    ) : void;

    //====================================================
    // Flip
    //====================================================

    fnc ImageFlipVertical(
        image pointer<Image>
    ) : void;

    fnc ImageFlipHorizontal(
        image pointer<Image>
    ) : void;

    //====================================================
    // Rotate
    //====================================================

    fnc ImageRotate(
        image pointer<Image>,
        degrees int
    ) : void;

    fnc ImageRotateCW(
        image pointer<Image>
    ) : void;

    fnc ImageRotateCCW(
        image pointer<Image>
    ) : void;

    //====================================================
    // Colors
    //====================================================

    fnc ImageColorTint(
        image pointer<Image>,
        color Color
    ) : void;

    fnc ImageColorInvert(
        image pointer<Image>
    ) : void;

    fnc ImageColorGrayscale(
        image pointer<Image>
    ) : void;

    fnc ImageColorContrast(
        image pointer<Image>,
        contrast float
    ) : void;

    fnc ImageColorBrightness(
        image pointer<Image>,
        brightness int
    ) : void;

    fnc ImageColorReplace(
        image pointer<Image>,
        color Color,
        replace Color
    ) : void;

    //====================================================
    // Pixel data
    //====================================================

    fnc LoadImageColors(
        image Image
    ) : pointer<Color>;

    fnc LoadImagePalette(
        image Image,
        maxPaletteSize int,
        colorCount pointer<int>
    ) : pointer<Color>;

    fnc UnloadImageColors(
        colors pointer<Color>
    ) : void;

    fnc UnloadImagePalette(
        colors pointer<Color>
    ) : void;

    fnc GetImageAlphaBorder(
        image Image,
        threshold float
    ) : Rectangle;

    fnc GetImageColor(
        image Image,
        x int,
        y int
    ) : Color;

    //====================================================
    // Texture loading
    //====================================================

    fnc LoadTexture(
        fileName string
    ) : Texture2D;

    fnc LoadTextureFromImage(
        image Image
    ) : Texture2D;

    fnc LoadTextureCubemap(
        image Image,
        layout int
    ) : TextureCubemap;

    fnc LoadRenderTexture(
        width int,
        height int
    ) : RenderTexture2D;

    fnc IsTextureValid(
        texture Texture2D
    ) : bool;

    fnc IsRenderTextureValid(
        target RenderTexture2D
    ) : bool;

    //====================================================
    // Texture unload
    //====================================================

    fnc UnloadTexture(
        texture Texture2D
    ) : void;

    fnc UnloadRenderTexture(
        target RenderTexture2D
    ) : void;

    //====================================================
    // Texture update (GPU Upload)
    //====================================================

    fnc UpdateTexture(
        texture Texture2D,
        pixels pointer<void>
    ) : void;

    fnc UpdateTextureRec(
        texture Texture2D,
        rec Rectangle,
        pixels pointer<void>
    ) : void;

    //====================================================
    // Texture filtering
    //====================================================

    fnc GenTextureMipmaps(
        texture pointer<Texture2D>
    ) : void;

    fnc SetTextureFilter(
        texture Texture2D,
        filter int
    ) : void;

    //====================================================
    // Texture wrapping
    //====================================================

    fnc SetTextureWrap(
        texture Texture2D,
        wrap int
    ) : void;

    //====================================================
    // RenderTexture
    //====================================================

    fnc BeginTextureMode(
        target RenderTexture2D
    ) : void;

    fnc EndTextureMode() : void;

    //====================================================
    // Cubemap helpers
    //====================================================

    fnc GenTextureCubemap(
        shader pointer<void>,
        panorama Texture2D,
        size int,
        format int
    ) : TextureCubemap;

    fnc GenTextureIrradiance(
        shader pointer<void>,
        cubemap TextureCubemap,
        size int
    ) : TextureCubemap;

    fnc GenTexturePrefilter(
        shader pointer<void>,
        cubemap TextureCubemap,
        size int
    ) : TextureCubemap;

    fnc GenTextureBRDF(
        shader pointer<void>,
        size int
    ) : Texture2D;

    //====================================================
    // Texture drawing
    //====================================================

    fnc DrawTexture(
        texture Texture2D,
        posX int,
        posY int,
        tint Color
    ) : void;

    fnc DrawTextureV(
        texture Texture2D,
        position Vector2,
        tint Color
    ) : void;

    fnc DrawTextureEx(
        texture Texture2D,
        position Vector2,
        rotation float<32>,
        scale float<32>,
        tint Color
    ) : void;

    fnc DrawTextureRec(
        texture Texture2D,
        source Rectangle,
        position Vector2,
        tint Color
    ) : void;

    fnc DrawTexturePro(
        texture Texture2D,
        source Rectangle,
        dest Rectangle,
        origin Vector2,
        rotation float<32>,
        tint Color
    ) : void;

    fnc DrawTextureNPatch(
        texture Texture2D,
        nPatchInfo NPatchInfo,
        dest Rectangle,
        origin Vector2,
        rotation float<32>,
        tint Color
    ) : void;

    //====================================================
    // RenderTexture drawing helpers
    //====================================================
    //
    // RenderTexture2D is drawn using the same DrawTexture*
    // functions because RenderTexture.texture is a Texture2D.
    //
    // Example:
    //
    // DrawTextureRec(
    //     target.texture,
    //     Rectangle {
