{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Leash",
    "scopeName": "source.leash",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#keywords" },
        { "include": "#constants" },
        { "include": "#numbers" },
        { "include": "#types" },
        { "include": "#functions" },
        { "include": "#operators" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.leash",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.leash",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.triple.double.leash",
                    "begin": "\"\"\"",
                    "end": "\"\"\""
                },
                {
                    "name": "string.quoted.triple.single.leash",
                    "begin": "'''",
                    "end": "'''"
                },
                {
                    "name": "string.quoted.double.leash",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.leash",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.leash",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.leash",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.leash",
                    "match": "\\b(return|if|else|unless|while|for|do|foreach|in|stop|continue|switch|case|default|defer|throw|try|catch)\\b"
                },
                {
                    "name": "keyword.declaration.leash",
                    "match": "\\b(fnc|def|struct|union|enum|class|type|template|macro|use|pub|priv|static|pubif|unsafe|as|inline|imut|create|del)\\b"
                },
                 {
                     "name": "keyword.other.leash",
                     "match": "\\b(this|self|also|alsou|works|otherwise|is|isnt)\\b"
                 }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.boolean.leash",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.language.null.leash",
                    "match": "\\b(null|nil)\\b"
                },
                {
                    "name": "variable.language.builtin.leash",
                    "match": "\\b(_FILEPATH|_FILENAME|_PLATFORM)\\b"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.leash",
                    "match": "\\b0[xX][0-9a-fA-F]+(\\.[0-9a-fA-F]*)?([pP][+-]?\\d+)?\\b"
                },
                {
                    "name": "constant.numeric.binary.leash",
                    "match": "\\b0[bB][01]+\\b"
                },
                {
                    "name": "constant.numeric.octal.leash",
                    "match": "\\b0[oO][0-7]+\\b"
                },
                {
                    "name": "constant.numeric.float.leash",
                    "match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b"
                },
                {
                    "name": "constant.numeric.decimal.leash",
                    "match": "\\b\\d+\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.primitive.leash",
                    "match": "\\b(int|uint|float|bool|string|char|void|array|vec|vector|hash)\\b"
                },
                {
                    "name": "storage.type.generic.leash",
                    "match": "hash<[^>]+>"
                },
                {
                    "name": "entity.name.type.leash",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "support.function.builtin.leash",
                    "match": "\\b(show|showb|get|set|toint|tofloat|tostring|cstr|lstr|size|cur|name|pushb|popb|pushf|popf|insert|clear|remove|extend|extendv|isin|rand|randf|seed|choose|wait|timepass|exit|exec|inttobytes|bytestoint|floattobytes|bytestofloat|open|close|read|write|readln|readb|writeb|readlnb|replaceall|rewind|rename|delete|replace|getKey|keys|values|push)\\b"
                },
                {
                    "name": "entity.name.function.leash",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.leash",
                    "match": "(\\|>|&&|\\|\\||<<|>>|\\+|-|\\*|/|%|&|\\||\\^|~|!|<|>|=|\\?|:)+"
                },
                {
                    "name": "keyword.operator.assignment.leash",
                    "match": ":="
                },
                {
                    "name": "keyword.operator.namespace.leash",
                    "match": "::"
                },
                {
                    "name": "keyword.operator.pointer.leash",
                    "match": "->"
                }
            ]
        }
    }
}
