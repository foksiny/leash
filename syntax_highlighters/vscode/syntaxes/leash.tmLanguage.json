{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Leash",
    "scopeName": "source.leash",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#builtins" },
        { "include": "#constants" },
        { "include": "#numbers" },
        { "include": "#attributes" },
        { "include": "#operators" },
        { "include": "#function-call" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.leash",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.leash",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.triple.double.leash",
                    "begin": "\"\"\"",
                    "end": "\"\"\""
                },
                {
                    "name": "string.quoted.triple.single.leash",
                    "begin": "'''",
                    "end": "'''"
                },
                {
                    "name": "string.quoted.double.leash",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.leash",
                            "match": "\\\\[0tnr\"'\\\\]"
                        },
                        {
                            "name": "constant.character.escape.hex.leash",
                            "match": "\\\\x[0-9a-fA-F]{2}"
                        },
                        {
                            "name": "constant.character.escape.unicode.leash",
                            "match": "\\\\u[0-9a-fA-F]{4}"
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.leash",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.leash",
                            "match": "\\\\[0tnr\"'\\\\]"
                        },
                        {
                            "name": "constant.character.escape.hex.leash",
                            "match": "\\\\x[0-9a-fA-F]{2}"
                        },
                        {
                            "name": "constant.character.escape.unicode.leash",
                            "match": "\\\\u[0-9a-fA-F]{4}"
                        }
                    ]
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.leash",
                    "match": "\\b(return|if|else|unless|also|alsou|while|for|do|foreach|loop|in|stop|break|continue|empty|ignore|switch|case|default|defer|throw|catch|try|works|otherwise)\\b"
                },
                {
                    "name": "keyword.declaration.leash",
                    "match": "\\b(fnc|def|struct|union|enum|class|type|template|macro|opdef|error|pub|priv|static|pubif|unsafe|as|inline|imut|create|del|extern|use|worker|shared|fusion|spawn)\\b"
                },
                {
                    "name": "keyword.other.leash",
                    "match": "\\b(this|thisop|self|is|isnt|end|thisworker)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.leash",
                    "match": "\\b(int|uint|float|bool|string|char|void|array|vec|vector|hash)\\b(?=\\s*[<(]|[^a-zA-Z0-9_])"
                },
                {
                    "name": "support.type.generic.leash",
                    "match": "\\b(vec|vector|hash|int|uint|float)<\\d+>"
                },
                {
                    "name": "support.type.bitwidth.leash",
                    "match": "\\b(int|uint|float)<\\d+>"
                },
                {
                    "name": "entity.name.type.leash",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
                },
                {
                    "name": "keyword.operator.pointer.leash",
                    "match": "[*&](?=[a-zA-Z_])"
                }
            ]
        },
        "builtins": {
            "patterns": [
                {
                    "name": "support.function.builtin.leash",
                    "match": "\\b(show|showb|get|keyget|set|toint|tofloat|tostring|cstr|lstr|normescape|sizeof|size|cur|name|pushb|popb|pushf|popf|insert|clear|remove|extend|extendv|isin|rand|randf|seed|choose|wait|timepass|exit|exec|inttobytes|bytestoint|floattobytes|bytestofloat|open|close|read|write|readln|readb|writeb|readlnb|replaceall|rewind|rename|delete|replace|getKey|getkey|keys|values|push|pop|front|back)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.boolean.leash",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.language.null.leash",
                    "match": "\\b(null|nil)\\b"
                },
                {
                    "name": "variable.language.builtin.leash",
                    "match": "\\b(_FILEPATH|_FILENAME|_PLATFORM|_ARGS)\\b"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.leash",
                    "match": "\\b0[xX][0-9a-fA-F]+(\\.[0-9a-fA-F]*)?([pP][+-]?\\d+)?\\b"
                },
                {
                    "name": "constant.numeric.binary.leash",
                    "match": "\\b0[bB][01]+\\b"
                },
                {
                    "name": "constant.numeric.octal.leash",
                    "match": "\\b0[oO][0-7]+\\b"
                },
                {
                    "name": "constant.numeric.float.leash",
                    "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
                },
                {
                    "name": "constant.numeric.decimal.leash",
                    "match": "\\b\\d+\\b(?!\\s*[.<(])"
                }
            ]
        },
        "attributes": {
            "patterns": [
                {
                    "name": "meta.annotation.leash",
                    "begin": "@from\\s*\\(",
                    "end": "\\)",
                    "patterns": [
                        { "include": "#strings" }
                    ]
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.leash",
                    "match": "(\\|>|&&|\\|\\||<<|>>|\\+\\+|--|[+\\-*/%&|^~!<>=]=?|<<=|>>=|&=|\\|=|^=)"
                },
                {
                    "name": "keyword.operator.assignment.leash",
                    "match": ":="
                },
                {
                    "name": "keyword.operator.namespace.leash",
                    "match": "::"
                },
                {
                    "name": "keyword.operator.pointer.leash",
                    "match": "->"
                },
                {
                    "name": "keyword.operator.in.leash",
                    "match": "<>"
                }
            ]
        },
        "function-call": {
            "patterns": [
                {
                    "name": "entity.name.function.leash",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
                },
                {
                    "name": "entity.name.function.definition.leash",
                    "match": "(?<=\\bfnc\\s+)[a-zA-Z_][a-zA-Z0-9_]*"
                }
            ]
        }
    }
}
