{
    "name": "leash",
    "displayName": "Leash",
    "description": "Leash Programming Language Support",
    "version": "0.1.0",
    "publisher": "leash-lang",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "activationEvents": [
        "onLanguage:leash"
    ],
    "main": "./out/client/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "leash",
                "aliases": [
                    "Leash",
                    "leash"
                ],
                "extensions": [
                    ".lsh"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "leash",
                "scopeName": "source.leash",
                "path": "./syntaxes/leash.tmLanguage.json"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "vsce package",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/node": "16.x",
        "@types/vscode": "^1.75.0",
        "@typescript-eslint/eslint-plugin": "^5.53.0",
        "@typescript-eslint/parser": "^5.53.0",
        "eslint": "^8.34.0",
        "typescript": "^4.9.5"
    },
    "dependencies": {
        "vscode-languageclient": "^8.1.0",
        "vscode-languageserver": "^8.1.0",
        "vscode-languageserver-textdocument": "^1.0.8",
        "vscode-uri": "^3.0.7"
    }
}
